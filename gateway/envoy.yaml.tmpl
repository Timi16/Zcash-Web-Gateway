# =============================================================================
# Zcash Web Gateway — Envoy Proxy Configuration Template
# =============================================================================
#
# This is a template file. ${UPSTREAM_HOST} and ${UPSTREAM_PORT} are
# substituted by entrypoint.sh at container start using envsubst.
#
# Purpose:
#   Translates browser gRPC-web (HTTP/1.1) requests into native gRPC (HTTP/2)
#   for lightwalletd or Zaino upstream.
#
# Upstream selector:
#   lightwalletd default: mainnet.lightwalletd.com:9067
#   Zaino default:        zaino.zfnd.org:8137
#
# Envoy version: v1.29.4 (pinned — do not change without testing)
#
# Reference: ZIP-307 Light Client Protocol
#   https://zips.z.cash/zip-0307
# =============================================================================

admin:
  # Bind admin interface to loopback only — never expose to public internet.
  address:
    socket_address:
      address: 127.0.0.1
      port_value: 9901

static_resources:

  # ---------------------------------------------------------------------------
  # LISTENERS
  # ---------------------------------------------------------------------------
  listeners:
    - name: zcash_gateway_listener
      address:
        socket_address:
          address: 0.0.0.0
          port_value: 8080

      filter_chains:
        - filters:
            - name: envoy.filters.network.http_connection_manager
              typed_config:
                "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager

                stat_prefix: zcash_gateway

                # ------------------------------------------------------------------
                # Access logging — privacy-preserving defaults.
                # Client IP intentionally omitted. To enable, add:
                #   "client_ip": "%DOWNSTREAM_REMOTE_ADDRESS%"
                # ------------------------------------------------------------------
                access_log:
                  - name: envoy.access_loggers.stdout
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.access_loggers.stream.v3.StdoutAccessLog
                      log_format:
                        json_format:
                          method:         "%REQ(:METHOD)%"
                          path:           "%REQ(X-ENVOY-ORIGINAL-PATH?:PATH)%"
                          protocol:       "%PROTOCOL%"
                          response_code:  "%RESPONSE_CODE%"
                          grpc_status:    "%GRPC_STATUS%"
                          duration_ms:    "%DURATION%"
                          bytes_received: "%BYTES_RECEIVED%"
                          bytes_sent:     "%BYTES_SENT%"
                          upstream_host:  "%UPSTREAM_HOST%"

                # ------------------------------------------------------------------
                # HTTP filter chain — ORDER MATTERS.
                # ------------------------------------------------------------------
                http_filters:

                  # 1. Health check — answers /healthz before hitting upstream
                  - name: envoy.filters.http.health_check
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.health_check.v3.HealthCheck
                      pass_through_mode: false
                      headers:
                        - name: ":path"
                          string_match:
                            exact: "/healthz"

                  # 2. CORS — handles browser preflight (OPTIONS) requests
                  - name: envoy.filters.http.cors
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.cors.v3.CorsPolicy

                  # 3. Rate limiting — per-connection token bucket, no external service.
                  #
                  #    Default limits (tuned for wallet traffic patterns):
                  #      300 tokens / 60s fill interval per connection.
                  #      A full wallet sync issues ~100-200 requests, so this gives
                  #      headroom for one sync plus ongoing mempool polling.
                  #
                  #    Behaviour on exhaustion:
                  #      Envoy returns HTTP 429. The gRPC-web client receives
                  #      gRPC status RESOURCE_EXHAUSTED (code 8).
                  #      Wallets should back off and retry — standard gRPC behaviour.
                  #
                  #    To tighten (e.g. public endpoint under abuse):
                  #      Lower max_tokens and tokens_per_fill.
                  #
                  #    To relax (e.g. internal operator endpoint):
                  #      Raise max_tokens or increase fill_interval.
                  #
                  - name: envoy.filters.http.local_ratelimit
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.local_ratelimit.v3.LocalRateLimit
                      stat_prefix: zcash_gateway_ratelimit
                      token_bucket:
                        max_tokens: 300
                        tokens_per_fill: 300
                        fill_interval: 60s
                      # Apply to every request by default.
                      # Per-route overrides can be added in typed_per_filter_config.
                      filter_enabled:
                        runtime_key: local_rate_limit_enabled
                        default_value:
                          numerator: 100
                          denominator: HUNDRED
                      filter_enforced:
                        runtime_key: local_rate_limit_enforced
                        default_value:
                          numerator: 100
                          denominator: HUNDRED
                      # Return gRPC-compatible 429 with Retry-After header.
                      response_headers_to_add:
                        - header:
                            key: x-local-rate-limit
                            value: "true"
                        - header:
                            key: retry-after
                            value: "60"

                  # 4. gRPC-web — core translation layer (HTTP/1.1 ↔ HTTP/2)
                  - name: envoy.filters.http.grpc_web
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.grpc_web.v3.GrpcWeb

                  # 4. Router — must always be last
                  - name: envoy.filters.http.router
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router

                # ------------------------------------------------------------------
                # Route configuration
                # ------------------------------------------------------------------
                route_config:
                  name: zcash_gateway_routes
                  virtual_hosts:
                    - name: zcash_gateway
                      domains: ["*"]

                      typed_per_filter_config:
                        envoy.filters.http.cors:
                          "@type": type.googleapis.com/envoy.extensions.filters.http.cors.v3.CorsPolicy
                          allow_origin_string_match:
                            - safe_regex:
                                regex: ".*"
                          allow_methods: "GET, POST, OPTIONS"
                          allow_headers: "content-type, x-grpc-web, x-user-agent, grpc-timeout, authorization"
                          expose_headers: "grpc-status, grpc-message, grpc-status-details-bin"
                          max_age: "1728000"

                      routes:

                        # Unary — fast reads
                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetLatestBlock"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 10s

                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetBlock"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 10s

                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetTransaction"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 15s

                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetTreeState"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 10s

                        # Write — transaction submission
                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/SendTransaction"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 30s

                        # Streaming — no timeout, runs until client disconnects
                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetBlockRange"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 0s

                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetMempoolStream"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 0s

                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetMempoolTx"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 0s

                        # Streaming — bounded
                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetAddressUtxosStream"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 30s

                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetTaddressTxids"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 30s

                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetSubtreeRoots"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 30s

                        # Unary — medium
                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetAddressUtxos"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 15s

                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetLatestTreeState"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 10s

                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetTaddressBalance"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 10s

                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer/GetLightdInfo"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 10s

                        # Catch-all
                        - match:
                            prefix: "/cash.z.wallet.sdk.rpc.CompactTxStreamer"
                          route:
                            cluster: lightwalletd_upstream
                            timeout: 20s

  # ---------------------------------------------------------------------------
  # CLUSTERS
  # ---------------------------------------------------------------------------
  clusters:
    - name: lightwalletd_upstream
      type: STRICT_DNS

      # Force HTTP/2 to upstream — lightwalletd and Zaino both require it.
      typed_extension_protocol_options:
        envoy.extensions.upstreams.http.v3.HttpProtocolOptions:
          "@type": type.googleapis.com/envoy.extensions.upstreams.http.v3.HttpProtocolOptions
          explicit_http_config:
            http2_protocol_options: {}

      # TLS block injected here by entrypoint.sh based on UPSTREAM_TLS env var.
      # UPSTREAM_TLS=true  → TLS transport_socket with SNI (public endpoints)
      # UPSTREAM_TLS=false → no block, plaintext HTTP/2 (local/testnet stacks)
${UPSTREAM_TLS_BLOCK}
      load_assignment:
        cluster_name: lightwalletd_upstream
        endpoints:
          - lb_endpoints:
              - endpoint:
                  address:
                    socket_address:
                      address: "${UPSTREAM_HOST}"
                      port_value: ${UPSTREAM_PORT}

      circuit_breakers:
        thresholds:
          - priority: DEFAULT
            max_connections: 1000
            max_pending_requests: 1000
            max_requests: 5000
            max_retries: 3

      upstream_connection_options:
        tcp_keepalive:
          keepalive_probes: 3
          keepalive_time: 30
          keepalive_interval: 10
